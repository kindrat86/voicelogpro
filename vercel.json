{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "github": {
    "silent": true
  },
  "regions": [
    "fra1"
  ],
  "cleanUrls": true,
  "trailingSlash": false,
  "buildCommand": "npm run build:all",
  "outputDirectory": "dist",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=63072000; includeSubDomains; preload"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=(), interest-cohort=()"
        },
        {
          "key": "X-Permitted-Cross-Domain-Policies",
          "value": "none"
        },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://eu.i.posthog.com https://us.i.posthog.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data: https: blob:; connect-src 'self' https://*.supabase.co https://eu.i.posthog.com https://email-engine-fawn.vercel.app; frame-src 'none'; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'; upgrade-insecure-requests"
        },
        {
          "key": "Access-Control-Allow-Origin",
          "value": "https://voicelogpro.com"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*\\.html)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600"
        }
      ]
    },
    {
      "source": "/sitemap.xml",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/weekly-reports/:slug",
      "destination": "/weekly-reports/:slug/index.html"
    },
    {
      "source": "/faq/:slug",
      "destination": "/faq/:slug/index.html"
    },
    {
      "source": "/tools/:slug",
      "destination": "/tools/:slug/index.html"
    },
    {
      "source": "/integrations/:slug",
      "destination": "/integrations/:slug/index.html"
    },
    {
      "source": "/pricing-questions/:slug",
      "destination": "/pricing-questions/:slug/index.html"
    },
    {
      "source": "/learn/:slug",
      "destination": "/learn/:slug/index.html"
    },
    {
      "source": "/use-cases/:slug",
      "destination": "/use-cases/:slug/index.html"
    },
    {
      "source": "/free/:slug",
      "destination": "/free/:slug/index.html"
    },
    {
      "source": "/alternatives-to/:slug",
      "destination": "/alternatives-to/:slug.html"
    },
    {
      "source": "/vs/:slug",
      "destination": "/vs/:slug.html"
    },
    {
      "source": "/for/:slug",
      "destination": "/for/:slug.html"
    },
    {
      "source": "/glossary/:slug",
      "destination": "/glossary/:slug.html"
    },
    {
      "source": "/best/:slug",
      "destination": "/best/:slug.html"
    },
    {
      "source": "/about",
      "destination": "/about.html"
    },
    {
      "source": "/contact",
      "destination": "/contact.html"
    },
    {
      "source": "/privacy",
      "destination": "/privacy.html"
    },
    {
      "source": "/terms",
      "destination": "/terms.html"
    },
    {
      "source": "/citations",
      "destination": "/citations.html"
    },
    {
      "source": "/faq",
      "destination": "/faq.html"
    },
    {
      "source": "/answers",
      "destination": "/answers.html"
    },
    {
      "source": "/AGENTS.md",
      "destination": "/agents.md"
    },
    {
      "source": "/agents.md",
      "destination": "/agents.md"
    },
    {
      "source": "/states/:slug",
      "destination": "/states/:slug/index.html"
    },
    {
      "source": "/templates/:slug",
      "destination": "/templates/:slug/index.html"
    },
    {
      "source": "/industries/:slug",
      "destination": "/industries/:slug.html"
    }
  ],
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "www.voicelogpro.com"
        }
      ],
      "destination": "https://voicelogpro.com/:path*",
      "permanent": true
    },
    {
      "source": "/solutions",
      "destination": "/solutions/texas-mechanics-lien-compliance",
      "permanent": true
    },
    {
      "source": "/states/texas-lien-law",
      "destination": "/blog/texas-property-code-chapter-53-guide-2025",
      "permanent": true
    }
  ]
}
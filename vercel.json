{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "github": {
    "silent": true
  },
  "regions": [
    "fra1"
  ],
  "cleanUrls": true,
  "trailingSlash": false,
  "buildCommand": "npm run build:all",
  "outputDirectory": "dist",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=63072000; includeSubDomains; preload"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=(), interest-cohort=()"
        },
        {
          "key": "X-Permitted-Cross-Domain-Policies",
          "value": "none"
        },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://eu.i.posthog.com https://us.i.posthog.com https://connect.facebook.net https://www.redditstatic.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data: https: blob: https://www.facebook.com; connect-src 'self' https://*.supabase.co https://eu.i.posthog.com https://email-engine-fawn.vercel.app; frame-src 'none'; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'; require-trusted-types-for 'script'; upgrade-insecure-requests"
        },
        {
          "key": "Access-Control-Allow-Origin",
          "value": "https://voicelogpro.com"
        },
        {
          "key": "Cross-Origin-Opener-Policy",
          "value": "same-origin"
        },
        {
          "key": "Cross-Origin-Embedder-Policy",
          "value": "credentialless"
        },
        {
          "key": "X-DNS-Prefetch-Control",
          "value": "on"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/images/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=2592000, stale-while-revalidate=86400"
        }
      ]
    },
    {
      "source": "/favicon.ico",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=2592000, stale-while-revalidate=86400"
        }
      ]
    },
    {
      "source": "/(.*\\.html)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600"
        }
      ]
    },
    {
      "source": "/sitemap.xml",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400"
        }
      ]
    },
    {
      "source": "/embed/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "ALLOWALL"
        },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; connect-src 'self'; frame-ancestors *"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/cities/:slug",
      "destination": "/cities/:slug/index.html"
    },
    {
      "source": "/alternatives/:slug",
      "destination": "/alternatives/:slug/index.html"
    },
    {
      "source": "/weekly-reports/:slug",
      "destination": "/weekly-reports/:slug/index.html"
    },
    {
      "source": "/faq/:slug",
      "destination": "/faq/:slug/index.html"
    },
    {
      "source": "/tools/:slug",
      "destination": "/tools/:slug/index.html"
    },
    {
      "source": "/integrations/:slug",
      "destination": "/integrations/:slug/index.html"
    },
    {
      "source": "/pricing-questions/:slug",
      "destination": "/pricing-questions/:slug/index.html"
    },
    {
      "source": "/learn/:slug",
      "destination": "/learn/:slug/index.html"
    },
    {
      "source": "/use-cases/:slug",
      "destination": "/use-cases/:slug/index.html"
    },
    {
      "source": "/free/:slug",
      "destination": "/free/:slug/index.html"
    },
    {
      "source": "/alternatives-to/:slug",
      "destination": "/alternatives-to/:slug.html"
    },
    {
      "source": "/vs/:slug",
      "destination": "/vs/:slug.html"
    },
    {
      "source": "/for/:slug",
      "destination": "/for/:slug.html"
    },
    {
      "source": "/glossary/:slug",
      "destination": "/glossary/:slug.html"
    },
    {
      "source": "/best/:slug",
      "destination": "/best/:slug.html"
    },
    {
      "source": "/privacy",
      "destination": "/privacy.html"
    },
    {
      "source": "/terms",
      "destination": "/terms.html"
    },
    {
      "source": "/citations",
      "destination": "/citations.html"
    },
    {
      "source": "/faq",
      "destination": "/faq.html"
    },
    {
      "source": "/answers",
      "destination": "/answers/index.html"
    },
    {
      "source": "/AGENTS.md",
      "destination": "/agents.md"
    },
    {
      "source": "/agents.md",
      "destination": "/agents.md"
    },
    {
      "source": "/states/:slug",
      "destination": "/states/:slug/index.html"
    },
    {
      "source": "/templates/:slug",
      "destination": "/templates/:slug/index.html"
    },
    {
      "source": "/industries/:slug",
      "destination": "/industries/:slug.html"
    },
    {
      "source": "/data",
      "destination": "/data/index.html"
    },
    {
      "source": "/data/",
      "destination": "/data/index.html"
    },
    {
      "source": "/data/(.*)/",
      "destination": "/data/$1/index.html"
    },
    {
      "source": "/data/(.*)",
      "destination": "/data/$1/index.html"
    }
  ],
  "redirects": [
    {
      "source": "/((?:en|zh-CN|hi|es|fr|ar|bn|pt|ru|ur|id|de|ja|mr|te|tr|ta|vi|yue|pa-PK|ko|fa|it|th|gu|kn|ml|or|pl|uk|nl|ro|el|cs|hu|sv|fi|no|da|he|sw|am|so|ha|yo|ig|zu|xh|af|ms|my|km|lo|ne|si|ps|kk|uz|az|ka|hy|mn|bo|ug|tl|ceb|ilo|jv|su|mad|hmn|ku|bal|tg|tk|sq|sr|hr|bs|sk|sl|lt|lv|et|be|bg|mk|ca|eu|gl|cy|ga|gd|br|is|lb|mt))$",
      "destination": "https://voicelogpro.com/",
      "permanent": false
    },
    {
      "source": "/((?:en|zh-CN|hi|es|fr|ar|bn|pt|ru|ur|id|de|ja|mr|te|tr|ta|vi|yue|pa-PK|ko|fa|it|th|gu|kn|ml|or|pl|uk|nl|ro|el|cs|hu|sv|fi|no|da|he|sw|am|so|ha|yo|ig|zu|xh|af|ms|my|km|lo|ne|si|ps|kk|uz|az|ka|hy|mn|bo|ug|tl|ceb|ilo|jv|su|mad|hmn|ku|bal|tg|tk|sq|sr|hr|bs|sk|sl|lt|lv|et|be|bg|mk|ca|eu|gl|cy|ga|gd|br|is|lb|mt))/(.*)",
      "destination": "/$2",
      "permanent": false
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "www.voicelogpro.com"
        }
      ],
      "destination": "https://voicelogpro.com/:path*",
      "permanent": true
    },
    {
      "source": "/solutions",
      "destination": "/solutions/texas-mechanics-lien-compliance",
      "permanent": true
    },
    {
      "source": "/states/texas-lien-law",
      "destination": "/blog/texas-property-code-chapter-53-guide-2025",
      "permanent": true
    },
    {
      "source": "/pricing",
      "destination": "/crew-plan",
      "permanent": true
    },
    {
      "source": "/features",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/integrations",
      "destination": "/integrations/autodesk",
      "permanent": true
    },
    {
      "source": "/integration",
      "destination": "/integrations/autodesk",
      "permanent": true
    }
  ]
}
